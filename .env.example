# .env.example for karda - authoritative reference for every supported
# variable. Copy to .env and fill in. .env is git-ignored and never committed.
# Convention: values below are the prod defaults; a "BETA OVERRIDES" note marks
# any key whose beta value differs. The beta values are FORWARD-LOOKING - beta is
# the org-standard second tier but is a reserved release channel awaiting its own
# server, so during the development phase only the prod column is live (TD-001).
# Secret keys are present-but-empty with a procurement note; real values are
# injected via env, never committed.

# --- App ---
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production          # BETA OVERRIDES: beta
APP_PUBLISH_PORT=3233                    # worker-02 allocation (arda 3230/3231, vxtpl 3232)

# --- Database (karda) ---
# Runtime connects as the least-privilege service role, not the DB owner.
POSTGRES_DB=vxturebiz_karda_prod     # BETA OVERRIDES: vxturebiz_karda_beta
POSTGRES_USER=karda_svc
POSTGRES_PASSWORD=                      # procure: KARDA_DB_SVC_PASSWORD
DATABASE_URL=postgresql://karda_svc:@karda-db:5432/vxturebiz_karda_prod

# --- Redis (RP session store) ---
REDIS_URL=redis://karda-redis:6379

# --- Status dashboard (/status, /api/status) ---
STATUS_PAGE=public                       # public | authed (login required) | off
STATUS_SHOW_INFRA=on                     # on shows db host/name/role; off hides them

# --- C1 OIDC RP (080-rp section 2.11) ---
OIDC_ISSUER=https://accounts.vxture.com
OIDC_CLIENT_ID=karda                   # BETA OVERRIDES: karda-beta
OIDC_CLIENT_SECRET=                      # procure: platform-issued client secret
OIDC_REDIRECT_URI=https://karda.vxture.com/auth/callback
OIDC_SCOPES=openid profile email phone
OIDC_POST_LOGOUT_REDIRECT_URI=https://karda.vxture.com/
OIDC_RP_ENABLED=on
RP_SESSION_TTL=2592000
RP_SESSION_COOKIE_NAME=__Host-vx_rp_session   # dev over http: vx_rp_session
NEXT_PUBLIC_APP_URL=https://karda.vxture.com

# --- C2 entitlement / platform client ---
PLATFORM_API_URL=                        # internal-network base; unset -> Mock resolver
PLATFORM_INTERNAL_AUTH_TOKEN=            # procure: shared internal-auth secret (S2S)
NEXT_PUBLIC_CONSOLE_URL=https://console.vxture.com

# --- C3 provisioning webhook / usage ---
PROVISION_WEBHOOK_SECRET=               # procure: KARDA_PROVISION_WEBHOOK_SECRET (platform key)
PROVISION_WEBHOOK_SECRET_NEXT=          # optional, rotation overlap
INTERNAL_JOB_TOKEN=                     # procure: gates POST /api/usage/flush
