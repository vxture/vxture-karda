// Prisma is the CLIENT-GENERATION SOURCE only (product_240 section 2.4 E). The
// DDL under deploy/database/ddl/ is the single structure authority; this schema
// stays in lockstep with it (enforced by check-data-architecture.mjs). There is
// no migrations directory - structure changes go through db-init, not prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["vx_provision", "local_authz", "local_usage", "karda_kb"]
}

// ===== vx_provision =====

model AppInstance {
  id            String    @id @default(uuid()) @db.Uuid
  workspaceId   String    @map("workspace_id") @db.Uuid
  tenantId      String?   @map("tenant_id") @db.Uuid
  productCode   String    @map("product_code") @db.VarChar(32)
  status        String    @default("pending") @db.VarChar(32)
  env           String    @default("prod") @db.VarChar(32)
  provisionedAt DateTime? @map("provisioned_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz()

  @@unique([workspaceId, productCode], map: "uidx_app_instance_ws_product")
  @@map("app_instance")
  @@schema("vx_provision")
}

model WebhookDelivery {
  id         String    @id @default(uuid()) @db.Uuid
  deliveryId String    @map("delivery_id") @db.VarChar(128)
  type       String    @db.VarChar(64)
  occurredAt DateTime? @map("occurred_at") @db.Timestamptz()
  result     String    @default("processed") @db.VarChar(32)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([deliveryId], map: "uidx_webhook_delivery_delivery_id")
  @@map("webhook_delivery")
  @@schema("vx_provision")
}

model ProvisionSeq {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  productCode String   @map("product_code") @db.VarChar(32)
  lastSeq     BigInt   @default(0) @map("last_seq")
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  @@unique([workspaceId, productCode], map: "uidx_provision_seq_ws_product")
  @@map("provision_seq")
  @@schema("vx_provision")
}

// ===== local_authz =====

model Member {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  sub         String   @db.VarChar(128)
  displayName String?  @map("display_name") @db.VarChar(255)
  avatarHash  String?  @map("avatar_hash") @db.VarChar(128)
  status      String   @default("active") @db.VarChar(32)
  firstSeenAt DateTime @default(now()) @map("first_seen_at") @db.Timestamptz()
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  @@unique([workspaceId, sub], map: "uidx_member_ws_sub")
  @@map("member")
  @@schema("local_authz")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  roleCode  String   @map("role_code") @db.VarChar(64)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([roleCode], map: "uidx_role_role_code")
  @@map("role")
  @@schema("local_authz")
}

model Permission {
  id        String   @id @default(uuid()) @db.Uuid
  permCode  String   @map("perm_code") @db.VarChar(64)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([permCode], map: "uidx_permission_perm_code")
  @@map("permission")
  @@schema("local_authz")
}

model MemberRole {
  id        String   @id @default(uuid()) @db.Uuid
  memberId  String   @map("member_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([memberId, roleId], map: "uidx_member_role_member_role")
  @@map("member_role")
  @@schema("local_authz")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([roleId, permissionId], map: "uidx_role_permission_role_perm")
  @@map("role_permission")
  @@schema("local_authz")
}

// ===== local_usage =====

model Raw {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  metric         String   @db.VarChar(128)
  amount         BigInt
  idempotencyKey String   @map("idempotency_key") @db.VarChar(128)
  flushed        Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([idempotencyKey], map: "uidx_raw_idempotency_key")
  @@map("raw")
  @@schema("local_usage")
}

model Checkpoint {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  metric      String   @db.VarChar(128)
  flushedAt   DateTime @default(now()) @map("flushed_at") @db.Timestamptz()

  @@unique([workspaceId, metric], map: "uidx_checkpoint_ws_metric")
  @@map("checkpoint")
  @@schema("local_usage")
}

// ===== karda_kb (domain; DDL authority = deploy/database/ddl/00_baseline.sql,
// design authority = docs/30-design/210-data-model.md) =====

model ProcessingTemplate {
  id            String   @id @default(uuid()) @db.Uuid
  templateCode  String   @map("template_code") @db.VarChar(64)
  name          String   @db.VarChar(255)
  version       Int      @default(1)
  defaultParams Json     @default("{}") @map("default_params")
  isPreset      Boolean  @default(true) @map("is_preset")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  knowledgeBases KnowledgeBase[]
  documents      Document[]

  @@unique([templateCode], map: "uidx_processing_template_code")
  @@map("processing_template")
  @@schema("karda_kb")
}

model ContentTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  templateCode String   @map("template_code") @db.VarChar(64)
  name         String   @db.VarChar(255)
  version      Int      @default(1)
  scope        String   @default("platform") @db.VarChar(16)
  workspaceId  String?  @map("workspace_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  fields  ContentTemplateField[]
  entries Entry[]

  @@unique([scope, workspaceId, templateCode, version], map: "uidx_content_template_identity")
  @@map("content_template")
  @@schema("karda_kb")
}

model ContentTemplateField {
  id            String   @id @default(uuid()) @db.Uuid
  templateId    String   @map("template_id") @db.Uuid
  fieldName     String   @map("field_name") @db.VarChar(64)
  valueType     String   @map("value_type") @db.VarChar(16)
  enumValues    Json?    @map("enum_values")
  required      Boolean  @default(false)
  retrievalRole String   @default("store_only") @map("retrieval_role") @db.VarChar(16)
  ontosType     String?  @map("ontos_type") @db.VarChar(128)
  position      Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  template ContentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, map: "fk_ct_field_template")

  @@unique([templateId, fieldName], map: "uidx_ct_field_template_name")
  @@map("content_template_field")
  @@schema("karda_kb")
}

model KnowledgeBase {
  id                        String    @id @default(uuid()) @db.Uuid
  workspaceId               String    @map("workspace_id") @db.Uuid
  ownerType                 String    @map("owner_type") @db.VarChar(16)
  ownerSub                  String?   @map("owner_sub") @db.VarChar(128)
  name                      String    @db.VarChar(255)
  description               String?
  publishState              String    @default("private") @map("publish_state") @db.VarChar(32)
  originKbId                String?   @map("origin_kb_id") @db.Uuid
  originSnapshotAt          DateTime? @map("origin_snapshot_at") @db.Timestamptz()
  processingTemplateId      String?   @map("processing_template_id") @db.Uuid
  processingParams          Json      @default("{}") @map("processing_params")
  embeddingModel            String?   @map("embedding_model") @db.VarChar(128)
  fulltextEnabled           Boolean   @default(true) @map("fulltext_enabled")
  graphEnabled              Boolean   @default(false) @map("graph_enabled")
  retrievalDefaults         Json      @default("{}") @map("retrieval_defaults")
  governanceEnabled         Boolean   @default(false) @map("governance_enabled")
  defaultVerifier           String?   @map("default_verifier") @db.VarChar(128)
  defaultVerifyIntervalDays Int?      @map("default_verify_interval_days")
  exemptSyncedContent       Boolean   @default(true) @map("exempt_synced_content")
  deletedAt                 DateTime? @map("deleted_at") @db.Timestamptz()
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                 DateTime  @default(now()) @map("updated_at") @db.Timestamptz()

  processingTemplate ProcessingTemplate? @relation(fields: [processingTemplateId], references: [id], map: "fk_kb_processing_template")
  folders            Folder[]
  metadataFields     KbMetadataField[]
  documents          Document[]
  entries            Entry[]
  bindings           Binding[]

  @@index([ownerType, ownerSub], map: "idx_kb_owner")
  @@map("knowledge_base")
  @@schema("karda_kb")
}

model Folder {
  id        String   @id @default(uuid()) @db.Uuid
  kbId      String   @map("kb_id") @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  knowledgeBase KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade, map: "fk_folder_kb")
  documents     Document[]
  entries       Entry[]

  @@unique([kbId, name], map: "uidx_folder_kb_name")
  @@map("folder")
  @@schema("karda_kb")
}

model KbMetadataField {
  id         String   @id @default(uuid()) @db.Uuid
  kbId       String   @map("kb_id") @db.Uuid
  fieldName  String   @map("field_name") @db.VarChar(64)
  valueType  String   @map("value_type") @db.VarChar(16)
  enumValues Json?    @map("enum_values")
  filterable Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  knowledgeBase KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade, map: "fk_kb_meta_kb")

  @@unique([kbId, fieldName], map: "uidx_kb_meta_kb_field")
  @@map("kb_metadata_field")
  @@schema("karda_kb")
}

model Document {
  id                   String    @id @default(uuid()) @db.Uuid
  kbId                 String    @map("kb_id") @db.Uuid
  folderId             String?   @map("folder_id") @db.Uuid
  title                String    @db.VarChar(512)
  mime                 String?   @db.VarChar(128)
  sizeBytes            BigInt?   @map("size_bytes")
  source               String    @db.VarChar(32)
  connectorCode        String?   @map("connector_code") @db.VarChar(64)
  sourceRef            Json?     @map("source_ref")
  storageRef           String?   @map("storage_ref") @db.VarChar(512)
  contentHash          String?   @map("content_hash") @db.VarChar(80)
  processingTemplateId String?   @map("processing_template_id") @db.Uuid
  contentState         String    @default("processing") @map("content_state") @db.VarChar(32)
  failureReason        String?   @map("failure_reason")
  failedAt             DateTime? @map("failed_at") @db.Timestamptz()
  verificationState    String    @default("unverified") @map("verification_state") @db.VarChar(32)
  verifier             String?   @db.VarChar(128)
  verifiedAt           DateTime? @map("verified_at") @db.Timestamptz()
  expiresAt            DateTime? @map("expires_at") @db.Timestamptz()
  sensitivity          String?   @db.VarChar(32)
  businessMeta         Json      @default("{}") @map("business_meta")
  createdInProduct     String?   @map("created_in_product") @db.VarChar(32)
  createdBy            String?   @map("created_by") @db.VarChar(128)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamptz()

  knowledgeBase      KnowledgeBase       @relation(fields: [kbId], references: [id], onDelete: Cascade, map: "fk_document_kb")
  folder             Folder?             @relation(fields: [folderId], references: [id], map: "fk_document_folder")
  processingTemplate ProcessingTemplate? @relation(fields: [processingTemplateId], references: [id], map: "fk_document_processing_template")
  chunks             Chunk[]

  @@index([kbId, contentState], map: "idx_document_kb_state")
  @@map("document")
  @@schema("karda_kb")
}

model Entry {
  id                String    @id @default(uuid()) @db.Uuid
  kbId              String    @map("kb_id") @db.Uuid
  folderId          String?   @map("folder_id") @db.Uuid
  title             String?   @db.VarChar(512)
  contentTemplateId String    @map("content_template_id") @db.Uuid
  templateVersion   Int       @default(1) @map("template_version")
  fields            Json      @default("{}")
  contentState      String    @default("draft") @map("content_state") @db.VarChar(32)
  failureReason     String?   @map("failure_reason")
  failedAt          DateTime? @map("failed_at") @db.Timestamptz()
  verificationState String    @default("unverified") @map("verification_state") @db.VarChar(32)
  verifier          String?   @db.VarChar(128)
  verifiedAt        DateTime? @map("verified_at") @db.Timestamptz()
  expiresAt         DateTime? @map("expires_at") @db.Timestamptz()
  sensitivity       String?   @db.VarChar(32)
  businessMeta      Json      @default("{}") @map("business_meta")
  createdInProduct  String?   @map("created_in_product") @db.VarChar(32)
  createdBy         String?   @map("created_by") @db.VarChar(128)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz()

  knowledgeBase   KnowledgeBase   @relation(fields: [kbId], references: [id], onDelete: Cascade, map: "fk_entry_kb")
  folder          Folder?         @relation(fields: [folderId], references: [id], map: "fk_entry_folder")
  contentTemplate ContentTemplate @relation(fields: [contentTemplateId], references: [id], map: "fk_entry_content_template")

  @@index([kbId, contentState], map: "idx_entry_kb_state")
  @@map("entry")
  @@schema("karda_kb")
}

model Chunk {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  ordinal    Int
  text       String
  tokenCount Int?     @map("token_count")
  vectorRef  String?  @map("vector_ref") @db.VarChar(128)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade, map: "fk_chunk_document")

  @@unique([documentId, ordinal], map: "uidx_chunk_document_ordinal")
  @@map("chunk")
  @@schema("karda_kb")
}

model Binding {
  id               String    @id @default(uuid()) @db.Uuid
  kbId             String    @map("kb_id") @db.Uuid
  connectorCode    String    @map("connector_code") @db.VarChar(64)
  externalSourceId String    @map("external_source_id") @db.VarChar(255)
  mode             String    @default("backfill") @db.VarChar(32)
  state            String    @default("active") @db.VarChar(32)
  cursor           String?   @db.VarChar(512)
  lastSyncedAt     DateTime? @map("last_synced_at") @db.Timestamptz()
  createdBy        String?   @map("created_by") @db.VarChar(128)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz()

  knowledgeBase KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade, map: "fk_binding_kb")

  @@unique([kbId, connectorCode, externalSourceId], map: "uidx_binding_kb_connector_source")
  @@index([state, connectorCode], map: "idx_binding_state")
  @@map("binding")
  @@schema("karda_kb")
}
